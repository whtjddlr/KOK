# NAVER Maps Web SDK
VITE_NAVER_MAP_KEY_ID=YOUR_NAVER_MAP_CLIENT_ID
VITE_NAVER_MAP_SUBMODULES=geocoder

# Supabase Auth / Database
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Server-only value for future backend use.
# Do not expose this in client-side code.
NAVER_MAP_CLIENT_SECRET=YOUR_NAVER_MAP_CLIENT_SECRET

# Optional: OpenAI key for AI-first region candidate generation.
# If omitted, the app falls back to the built-in candidate logic.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# Optional: Upstage key for AI-first region candidate generation.
# Uses the OpenAI-compatible Chat Completions endpoint.
UPSTAGE_API_KEY=YOUR_UPSTAGE_API_KEY
UPSTAGE_MODEL=solar-pro3
UPSTAGE_API_BASE_URL=https://api.upstage.ai/v1

# Optional: NAVER Search API for future venue search expansion.
NAVER_SEARCH_CLIENT_ID=YOUR_NAVER_SEARCH_CLIENT_ID
NAVER_SEARCH_CLIENT_SECRET=YOUR_NAVER_SEARCH_CLIENT_SECRET
